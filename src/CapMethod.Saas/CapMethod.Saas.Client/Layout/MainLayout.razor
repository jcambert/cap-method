@namespace CapMethod.Saas.Client.Layout
@inherits Microsoft.AspNetCore.Components.LayoutComponentBase
@using Microsoft.AspNetCore.Components.Routing

<div class="cap-app-shell">
    <aside class="cap-sidebar">
        <div class="cap-brand">
            <p class="cap-kicker">CAP Method</p>
            <h1>SaaS</h1>
            <p>v3.1 production-ready</p>
        </div>

        <nav class="cap-nav" aria-label="Navigation principale">
            <NavLink href="/" Match="NavLinkMatch.All" class="cap-nav-link">Tableau de bord</NavLink>
            <NavLink href="/beneficiaries" class="cap-nav-link">Bénéficiaires</NavLink>
            <NavLink href="/cap-sessions" class="cap-nav-link">Sessions CAP</NavLink>
        </nav>
    </aside>

    <div class="cap-main-panel">
        <header class="cap-topbar">
            <div>
                <p class="cap-kicker">Production-ready track</p>
                <strong>Navigation SaaS par pages</strong>
            </div>
            <span class="cap-version-pill">Lot 1</span>
        </header>

        <main class="cap-page-content">
            @Body
        </main>
    </div>
</div>

<style>
    :root {
        color: #0f172a;
        background: #f8fafc;
    }

    body {
        margin: 0;
        font-family: system-ui, sans-serif;
        background: #f8fafc;
    }

    .cap-app-shell {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 280px minmax(0, 1fr);
    }

    .cap-sidebar {
        border-right: 1px solid #d6d9df;
        background: #ffffff;
        padding: 28px;
    }

    .cap-brand {
        border: 1px solid #d6d9df;
        border-radius: 18px;
        padding: 20px;
        margin-bottom: 24px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    }

    .cap-brand h1 {
        margin: 0;
    }

    .cap-brand p:last-child {
        margin-bottom: 0;
    }

    .cap-nav {
        display: grid;
        gap: 10px;
    }

    .cap-nav-link {
        display: block;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 12px 14px;
        color: #0f172a;
        font-weight: 800;
        text-decoration: none;
        background: #ffffff;
    }

    .cap-nav-link.active {
        border-color: #2563eb;
        background: #eff6ff;
        color: #1d4ed8;
    }

    .cap-main-panel {
        min-width: 0;
    }

    .cap-topbar {
        position: sticky;
        top: 0;
        z-index: 10;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        border-bottom: 1px solid #d6d9df;
        background: rgba(255, 255, 255, 0.96);
        padding: 18px 32px;
    }

    .cap-version-pill {
        border: 1px solid #cbd5e1;
        border-radius: 999px;
        padding: 8px 12px;
        font-weight: 800;
        background: #ffffff;
    }

    .cap-page-content {
        max-width: 1120px;
        margin: 0 auto;
        padding: 32px;
    }

    .cap-hero,
    .cap-card {
        border: 1px solid #d6d9df;
        border-radius: 18px;
        padding: 24px;
        margin-bottom: 18px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    }

    .cap-success-card {
        border-color: #16a34a;
    }

    .cap-detail-card {
        border-color: #2563eb;
    }

    .cap-selected-row {
        background: #eff6ff;
    }

    .cap-kicker {
        margin: 0 0 8px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.78rem;
        color: #475569;
    }

    .cap-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 18px;
    }

    .cap-form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 14px;
        margin-top: 18px;
    }

    label {
        display: grid;
        gap: 6px;
        font-weight: 700;
    }

    .cap-checkbox {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 18px;
    }

    input {
        border: 1px solid #cbd5e1;
        border-radius: 12px;
        padding: 10px 12px;
        font: inherit;
    }

    input[type="checkbox"] {
        width: 18px;
        height: 18px;
        padding: 0;
    }

    button,
    .cap-link-button {
        display: inline-block;
        border: 0;
        border-radius: 999px;
        padding: 10px 16px;
        cursor: pointer;
        font-weight: 700;
        text-decoration: none;
        color: #0f172a;
        background: #e2e8f0;
    }

    button:disabled {
        cursor: not-allowed;
        opacity: 0.6;
    }

    .cap-message {
        margin-top: 16px;
        font-weight: 700;
    }

    .cap-table-wrap {
        overflow-x: auto;
        margin-top: 18px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.92rem;
    }

    th,
    td {
        border-bottom: 1px solid #e2e8f0;
        padding: 10px;
        text-align: left;
        vertical-align: top;
        word-break: break-all;
    }

    th {
        font-weight: 800;
    }

    dl {
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 8px 16px;
    }

    dt {
        font-weight: 700;
    }

    dd {
        margin: 0;
        word-break: break-all;
    }

    @@media (max-width: 820px) {
        .cap-app-shell {
            grid-template-columns: 1fr;
        }

        .cap-sidebar {
            border-right: 0;
            border-bottom: 1px solid #d6d9df;
        }

        .cap-page-content,
        .cap-topbar,
        .cap-sidebar {
            padding: 20px;
        }
    }
</style>
