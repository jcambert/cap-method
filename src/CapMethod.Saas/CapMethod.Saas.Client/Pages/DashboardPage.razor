@page "/"
@namespace CapMethod.Saas.Client.Pages
@using CapMethod.Saas.Client.Auth
@using CapMethod.Saas.Client.Components
@inject CapMethodApiClient ApiClient

<section class="cap-hero">
    <p class="cap-kicker">CAP Method SaaS</p>
    <h1>Tableau de bord</h1>
    <p>Socle v3.0 publié. Le cycle v3.1 prépare la mise en production métier avec une authentification minimale exploitable.</p>
</section>

<section class="cap-card">
    <h2>Connexion</h2>
    <p>Le point d'entrée principal utilise <code>POST /api/auth/token</code>. Le bouton de connexion dev reste disponible uniquement pour le développement local.</p>

    <div class="cap-form-grid">
        <label>
            Email
            <input @bind="_email" placeholder="admin@cap-method.local" />
        </label>
        <label>
            Mot de passe
            <input type="password" @bind="_password" placeholder="Mot de passe" />
        </label>
    </div>

    <div class="cap-actions">
        <button @onclick="LoginAsync" disabled="@_isBusy">Connexion</button>
        <button @onclick="LoginDevelopmentAsync" disabled="@_isBusy">Connexion dev</button>
        <button @onclick="LoadCurrentUserAsync" disabled="@_isBusy">Lire /api/me</button>
        <button @onclick="LogoutAsync" disabled="@_isBusy">Déconnexion</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <p class="cap-message">@_message</p>
    }
</section>

<AuthSummaryCard Token="_token" CurrentUser="_currentUser" />

<section class="cap-card">
    <h2>Accès rapides</h2>
    <div class="cap-actions">
        <a class="cap-link-button" href="/beneficiaries">Créer un bénéficiaire</a>
        <a class="cap-link-button" href="/cap-sessions">Gérer les sessions CAP</a>
    </div>
</section>

@code {
    private bool _isBusy;
    private string? _message;
    private AccessTokenResponse? _token;
    private CurrentUserResponse? _currentUser;
    private string _email = "admin@cap-method.local";
    private string _password = string.Empty;

    private async Task LoginAsync()
    {
        await RunAsync(async () =>
        {
            if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
            {
                throw new InvalidOperationException("L'email et le mot de passe sont obligatoires.");
            }

            _token = await ApiClient.LoginAsync(_email, _password, CancellationToken.None);
            _currentUser = await ApiClient.GetCurrentUserAsync(CancellationToken.None);
            _message = "Connexion réussie.";
        });
    }

    private async Task LoginDevelopmentAsync()
    {
        await RunAsync(async () =>
        {
            _token = await ApiClient.CreateDevelopmentTokenAsync(CancellationToken.None);
            _currentUser = await ApiClient.GetCurrentUserAsync(CancellationToken.None);
            _message = "Connexion développement réussie.";
        });
    }

    private async Task LoadCurrentUserAsync()
    {
        await RunAsync(async () =>
        {
            _currentUser = await ApiClient.GetCurrentUserAsync(CancellationToken.None);
            _message = "Contexte serveur chargé.";
        });
    }

    private async Task LogoutAsync()
    {
        await RunAsync(async () =>
        {
            await ApiClient.LogoutAsync();
            _token = null;
            _currentUser = null;
            _password = string.Empty;
            _message = "Déconnexion locale effectuée.";
        });
    }

    private async Task RunAsync(Func<Task> action)
    {
        _isBusy = true;
        _message = null;

        try
        {
            await action();
        }
        catch (Exception exception)
        {
            _message = exception.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }
}
