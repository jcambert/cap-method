@page "/cap-sessions"
@namespace CapMethod.Saas.Client.Pages
@using CapMethod.Saas.Client.ActionPlans
@using CapMethod.Saas.Client.Auth
@using CapMethod.Saas.Client.Components
@using CapMethod.Saas.Client.Synthesis
@using CapMethod.Saas.Shared.ActionPlans
@using CapMethod.Saas.Shared.CapSessions
@using CapMethod.Saas.Shared.Synthesis
@inject CapMethodApiClient ApiClient
@inject SynthesisApiClient SynthesisApiClient
@inject ActionPlanApiClient ActionPlanApiClient

<section class="cap-hero">
    <p class="cap-kicker">Espace consultant</p>
    <h1>Sessions CAP</h1>
    <p>Créer, suivre, produire une synthèse validée et formaliser un plan d'action opérationnel.</p>
</section>

<section class="cap-card">
    <h2>Créer une session CAP</h2>
    <p>Le bénéficiaire doit exister dans le tenant courant. Le consultant et le tenant sont résolus côté serveur.</p>

    <div class="cap-form-grid">
        <label>
            Identifiant bénéficiaire
            <input @bind="_beneficiaryIdText" placeholder="00000000-0000-0000-0000-000000000000" />
        </label>
    </div>

    <label class="cap-checkbox">
        <input type="checkbox" @bind="EnableAiForSession" />
        Activer l'IA pour cette session
    </label>

    <div class="cap-actions">
        <button @onclick="CreateCapSessionAsync" disabled="@_isBusy">Créer la session CAP</button>
        <button @onclick="LoadCapSessionsAsync" disabled="@_isBusy">Rafraîchir les sessions</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <p class="cap-message">@_message</p>
    }
</section>

@if (_createdSession is not null)
{
    <section class="cap-card cap-success-card">
        <h2>Session CAP créée</h2>
        <dl>
            <dt>Session</dt>
            <dd>@_createdSession.CapSessionId</dd>
            <dt>Tenant</dt>
            <dd>@_createdSession.TenantId</dd>
            <dt>Bénéficiaire</dt>
            <dd>@_createdSession.BeneficiaryId</dd>
            <dt>Consultant</dt>
            <dd>@_createdSession.ConsultantId</dd>
            <dt>Statut</dt>
            <dd>@_createdSession.Status</dd>
            <dt>IA activée</dt>
            <dd>@_createdSession.IsAiEnabled</dd>
            <dt>Créée UTC</dt>
            <dd>@_createdSession.CreatedAtUtc</dd>
        </dl>
    </section>
}

<CapSessionListCard
    Sessions="_capSessions"
    SelectedSessionId="_selectedSession?.CapSessionId"
    IsBusy="_isBusy"
    RefreshRequested="LoadCapSessionsAsync"
    DetailRequested="LoadCapSessionDetailAsync" />

<CapSessionDetailCard Session="_selectedSession" />

@if (_selectedSession is not null && _synthesis is not null)
{
    <section class="cap-card cap-detail-card">
        <h2>Synthèse éditable</h2>
        <p>
            Brouillon généré depuis l'analyse structurée. Le contenu doit être relu, reformulé et validé par le consultant.
        </p>

        <textarea rows="24"
                  maxlength="30000"
                  @bind="_synthesisContent"
                  disabled="@(_isBusy || _synthesis.IsValidated)"></textarea>

        <div class="cap-actions">
            <button @onclick="SaveSynthesisDraftAsync"
                    disabled="@(_isBusy || _synthesis.IsValidated)">
                Enregistrer le brouillon
            </button>
            <button @onclick="ValidateSynthesisAsync"
                    disabled="@(_isBusy || _synthesis.IsValidated)">
                Valider humainement
            </button>
        </div>

        <dl>
            <dt>État</dt>
            <dd>@(_synthesis.IsValidated ? "Validée" : "Brouillon")</dd>
            <dt>Mise à jour UTC</dt>
            <dd>@_synthesis.UpdatedAtUtc</dd>
            @if (_synthesis.ValidatedAtUtc is not null)
            {
                <dt>Validation UTC</dt>
                <dd>@_synthesis.ValidatedAtUtc</dd>
                <dt>Validée par</dt>
                <dd>@_synthesis.ValidatedByUserId</dd>
            }
        </dl>
    </section>
}

@if (_selectedSession is not null && _actionPlan is not null)
{
    <section class="cap-card cap-detail-card">
        <h2>Plan d'action</h2>
        <p>
            Transformer la synthèse validée en actions concrètes, priorisées et suivables avec le bénéficiaire.
        </p>

        <div class="cap-form-grid">
            <label>
                Action
                <input @bind="_actionTitle" maxlength="180" placeholder="Ex. Mettre à jour le CV" disabled="@(_isBusy || _actionPlan.IsValidated)" />
            </label>
            <label>
                Catégorie
                <input @bind="_actionCategory" maxlength="120" placeholder="Ex. Positionnement" disabled="@(_isBusy || _actionPlan.IsValidated)" />
            </label>
            <label>
                Priorité
                <input @bind="_actionPriority" maxlength="40" placeholder="Haute, moyenne ou basse" disabled="@(_isBusy || _actionPlan.IsValidated)" />
            </label>
            <label>
                Échéance
                <input type="date" @bind="_actionDueDate" disabled="@(_isBusy || _actionPlan.IsValidated)" />
            </label>
        </div>

        <label>
            Description
            <textarea rows="5" maxlength="2000" @bind="_actionDescription" disabled="@(_isBusy || _actionPlan.IsValidated)"></textarea>
        </label>

        <div class="cap-actions">
            <button @onclick="AddActionItemAsync" disabled="@(_isBusy || _actionPlan.IsValidated)">Ajouter l'action</button>
            <button @onclick="ValidateActionPlanAsync" disabled="@(_isBusy || _actionPlan.IsValidated || _actionPlan.Items.Count == 0)">Valider le plan d'action</button>
        </div>

        <dl>
            <dt>État</dt>
            <dd>@(_actionPlan.IsValidated ? "Validé" : "Brouillon")</dd>
            <dt>Actions</dt>
            <dd>@_actionPlan.Items.Count</dd>
            <dt>Mise à jour UTC</dt>
            <dd>@_actionPlan.UpdatedAtUtc</dd>
        </dl>

        @if (_actionPlan.Items.Count > 0)
        {
            <ul class="cap-list">
                @foreach (ActionPlanItemResponse item in _actionPlan.Items)
                {
                    <li>
                        <strong>@item.Title</strong>
                        <span>@item.Category · @item.Priority · @item.Status</span>
                        <p>@item.Description</p>
                        @if (item.DueDate is not null)
                        {
                            <small>Échéance : @item.DueDate</small>
                        }
                        @if (item.Status != "Completed")
                        {
                            <button @onclick="() => CompleteActionItemAsync(item.ItemId)" disabled="@_isBusy">Marquer terminée</button>
                        }
                    </li>
                }
            </ul>
        }
    </section>
}

@code {
    private bool _isBusy;
    private string? _message;
    private string _beneficiaryIdText = string.Empty;
    private string _synthesisContent = string.Empty;
    private string _actionTitle = string.Empty;
    private string _actionDescription = string.Empty;
    private string _actionCategory = "Projet professionnel";
    private string _actionPriority = "Moyenne";
    private DateOnly? _actionDueDate;
    private CapSessionResponse? _createdSession;
    private CapSessionResponse? _selectedSession;
    private SynthesisResponse? _synthesis;
    private ActionPlanResponse? _actionPlan;
    private IReadOnlyCollection<CapSessionSummaryResponse> _capSessions = [];

    private bool EnableAiForSession { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadCapSessionsAsync();
    }

    private async Task CreateCapSessionAsync()
    {
        await RunAsync(async () =>
        {
            if (!Guid.TryParse(_beneficiaryIdText, out Guid beneficiaryId))
            {
                throw new InvalidOperationException("L'identifiant bénéficiaire doit être un Guid valide.");
            }

            _createdSession = await ApiClient.CreateCapSessionAsync(
                beneficiaryId,
                EnableAiForSession,
                CancellationToken.None);
            _selectedSession = _createdSession;
            await LoadSynthesisCoreAsync(_createdSession.BeneficiaryId);
            await LoadActionPlanCoreAsync(_createdSession.BeneficiaryId);
            _capSessions = await ApiClient.ListCapSessionsAsync(CancellationToken.None);
            _message = "Session CAP créée avec succès.";
        });
    }

    private async Task LoadCapSessionsAsync()
    {
        await RunAsync(async () =>
        {
            _capSessions = await ApiClient.ListCapSessionsAsync(CancellationToken.None);
            _message = $"Sessions chargées : {_capSessions.Count}.";
        });
    }

    private async Task LoadCapSessionDetailAsync(Guid capSessionId)
    {
        await RunAsync(async () =>
        {
            _selectedSession = await ApiClient.GetCapSessionAsync(capSessionId, CancellationToken.None);
            await LoadSynthesisCoreAsync(_selectedSession.BeneficiaryId);
            await LoadActionPlanCoreAsync(_selectedSession.BeneficiaryId);
            _message = "Détail session, synthèse et plan d'action chargés.";
        });
    }

    private Task SaveSynthesisDraftAsync()
    {
        return SaveSynthesisAsync(validate: false);
    }

    private Task ValidateSynthesisAsync()
    {
        return SaveSynthesisAsync(validate: true);
    }

    private async Task SaveSynthesisAsync(bool validate)
    {
        if (_selectedSession is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            _synthesis = await SynthesisApiClient.SaveAsync(
                _selectedSession.BeneficiaryId,
                _synthesisContent,
                validate,
                CancellationToken.None);
            _synthesisContent = _synthesis.Content;
            _message = validate ? "Synthèse validée humainement." : "Brouillon de synthèse enregistré.";
        });
    }

    private async Task AddActionItemAsync()
    {
        if (_selectedSession is null || _actionPlan is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            List<SaveActionPlanItemRequest> items = _actionPlan.Items
                .Select(item => new SaveActionPlanItemRequest(
                    item.ItemId,
                    item.Title,
                    item.Description,
                    item.Category,
                    item.Priority,
                    item.DueDate))
                .ToList();

            items.Add(new SaveActionPlanItemRequest(
                null,
                _actionTitle,
                _actionDescription,
                _actionCategory,
                _actionPriority,
                _actionDueDate));

            _actionPlan = await ActionPlanApiClient.SaveAsync(
                _selectedSession.BeneficiaryId,
                items,
                validate: false,
                CancellationToken.None);

            _actionTitle = string.Empty;
            _actionDescription = string.Empty;
            _actionCategory = "Projet professionnel";
            _actionPriority = "Moyenne";
            _actionDueDate = null;
            _message = "Action ajoutée au plan.";
        });
    }

    private async Task ValidateActionPlanAsync()
    {
        if (_selectedSession is null || _actionPlan is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            SaveActionPlanItemRequest[] items = _actionPlan.Items
                .Select(item => new SaveActionPlanItemRequest(
                    item.ItemId,
                    item.Title,
                    item.Description,
                    item.Category,
                    item.Priority,
                    item.DueDate))
                .ToArray();

            _actionPlan = await ActionPlanApiClient.SaveAsync(
                _selectedSession.BeneficiaryId,
                items,
                validate: true,
                CancellationToken.None);
            _message = "Plan d'action validé.";
        });
    }

    private async Task CompleteActionItemAsync(Guid itemId)
    {
        if (_selectedSession is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            _actionPlan = await ActionPlanApiClient.CompleteItemAsync(
                _selectedSession.BeneficiaryId,
                itemId,
                CancellationToken.None);
            _message = "Action marquée comme terminée.";
        });
    }

    private async Task LoadSynthesisCoreAsync(Guid beneficiaryId)
    {
        _synthesis = await SynthesisApiClient.GetAsync(beneficiaryId, CancellationToken.None);
        _synthesisContent = _synthesis.Content;
    }

    private async Task LoadActionPlanCoreAsync(Guid beneficiaryId)
    {
        _actionPlan = await ActionPlanApiClient.GetAsync(beneficiaryId, CancellationToken.None);
    }

    private async Task RunAsync(Func<Task> action)
    {
        _isBusy = true;
        _message = null;

        try
        {
            await action();
        }
        catch (Exception exception)
        {
            _message = exception.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }
}
