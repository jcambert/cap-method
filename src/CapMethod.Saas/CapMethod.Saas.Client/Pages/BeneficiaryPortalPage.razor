@page "/beneficiary"
@namespace CapMethod.Saas.Client.Pages
@using CapMethod.Saas.Client.Auth
@using CapMethod.Saas.Client.Questionnaires
@using CapMethod.Saas.Shared.Analysis
@using CapMethod.Saas.Shared.Questionnaires
@inject CapMethodApiClient ApiClient
@inject BeneficiaryQuestionnaireApiClient QuestionnaireApiClient

<section class="cap-hero">
    <p class="cap-kicker">Espace bénéficiaire</p>
    <h1>Questionnaires et analyse structurée</h1>
    <p>Connexion sécurisée, saisie des questionnaires et restitution d’indicateurs déterministes.</p>
</section>

<section class="cap-card cap-beneficiary-card">
    <h2>Connexion bénéficiaire</h2>
    <div class="cap-form-grid">
        <label>
            Email bénéficiaire
            <input @bind="_email" placeholder="beneficiaire@cap-method.local" />
        </label>
        <label>
            Code d'accès
            <input type="password" @bind="_accessCode" placeholder="Code envoyé au bénéficiaire" />
        </label>
    </div>
    <div class="cap-actions">
        <button @onclick="LoginBeneficiaryAsync" disabled="@_isBusy">Connexion et chargement</button>
        <button @onclick="LoadQuestionnairesAsync" disabled="@_isBusy">Actualiser</button>
        <button @onclick="LoadAnalysisAsync" disabled="@(_isBusy || _context is null)">Générer l’analyse</button>
        <button @onclick="LogoutAsync" disabled="@_isBusy">Déconnexion locale</button>
    </div>
    @if (!string.IsNullOrWhiteSpace(_message))
    {
        <p class="cap-message">@_message</p>
    }
</section>

@if (_context is not null)
{
    <section class="cap-card cap-success-card">
        <h2>Session bénéficiaire</h2>
        <p><strong>@_context.Email</strong> — bénéficiaire @_context.BeneficiaryId</p>
    </section>
}

@if (_questionnaires.Count > 0)
{
    <section class="cap-card">
        <h2>Mes questionnaires</h2>
        <div class="cap-actions">
            @foreach (QuestionnaireDefinitionResponse questionnaire in _questionnaires)
            {
                <button @onclick="() => SelectQuestionnaireAsync(questionnaire)" disabled="@_isBusy">
                    @questionnaire.Title
                </button>
            }
        </div>
    </section>
}

@if (_selectedQuestionnaire is not null)
{
    <section class="cap-card cap-detail-card">
        <h2>@_selectedQuestionnaire.Title</h2>
        <p>@_selectedQuestionnaire.Description</p>

        @foreach (QuestionnaireQuestionResponse question in _selectedQuestionnaire.Questions)
        {
            <label class="cap-questionnaire-question">
                <strong>@question.Label</strong>
                @if (question.IsRequired)
                {
                    <span>Obligatoire</span>
                }
                <textarea rows="5"
                          maxlength="@question.MaximumLength"
                          value="@GetAnswer(question.QuestionId)"
                          @oninput="eventArgs => SetAnswer(question.QuestionId, eventArgs.Value?.ToString())"></textarea>
            </label>
        }

        <div class="cap-actions">
            <button @onclick="SaveDraftAsync" disabled="@_isBusy">Enregistrer le brouillon</button>
            <button @onclick="SubmitAsync" disabled="@_isBusy">Soumettre</button>
        </div>

        @if (_progress is not null)
        {
            <p>
                Progression : @_progress.AnsweredQuestions / @_progress.TotalQuestions —
                @(_progress.IsSubmitted ? "Soumis" : "Brouillon")
            </p>
        }
    </section>
}

@if (_analysis is not null)
{
    <section class="cap-card cap-detail-card">
        <h2>Analyse structurée</h2>
        <p>
            @_analysis.SubmittedQuestionnaires questionnaire(s) soumis,
            @_analysis.TotalAnswers réponse(s), @_analysis.TotalCharacters caractères analysés.
        </p>
        <p><strong>Complétude globale : @_analysis.CompletionScore / 100</strong></p>

        <h3>Indicateurs</h3>
        <div class="cap-form-grid">
            @foreach (StructuredAnalysisIndicatorResponse indicator in _analysis.Indicators)
            {
                <article class="cap-card">
                    <strong>@indicator.Label</strong>
                    <p>@indicator.Score / @indicator.MaximumScore</p>
                    <small>@indicator.Evidence</small>
                </article>
            }
        </div>

        <h3>Mots-clés dominants</h3>
        @if (_analysis.Keywords.Count == 0)
        {
            <p>Aucun mot-clé significatif tant qu’aucun questionnaire n’est soumis.</p>
        }
        else
        {
            <p>@string.Join(" · ", _analysis.Keywords)</p>
        }
        <small>Analyse générée le @_analysis.GeneratedAtUtc.ToLocalTime().</small>
    </section>
}

@code {
    private readonly Dictionary<string, string> _answers = new(StringComparer.Ordinal);
    private readonly List<QuestionnaireDefinitionResponse> _questionnaires = [];
    private bool _isBusy;
    private string? _message;
    private string _email = "beneficiaire@cap-method.local";
    private string _accessCode = string.Empty;
    private BeneficiaryPortalContextResponse? _context;
    private QuestionnaireDefinitionResponse? _selectedQuestionnaire;
    private QuestionnaireProgressResponse? _progress;
    private StructuredAnalysisResponse? _analysis;

    private async Task LoginBeneficiaryAsync()
    {
        await RunAsync(async () =>
        {
            await ApiClient.LoginBeneficiaryPortalAsync(_email, _accessCode, CancellationToken.None);
            _context = await ApiClient.GetBeneficiaryPortalContextAsync(CancellationToken.None);
            await LoadQuestionnairesCoreAsync();
            _analysis = await QuestionnaireApiClient.GetStructuredAnalysisAsync(CancellationToken.None);
            _message = "Connexion bénéficiaire réussie.";
        });
    }

    private async Task LoadQuestionnairesAsync()
    {
        await RunAsync(async () =>
        {
            _context = await ApiClient.GetBeneficiaryPortalContextAsync(CancellationToken.None);
            await LoadQuestionnairesCoreAsync();
            _message = "Questionnaires actualisés.";
        });
    }

    private async Task LoadAnalysisAsync()
    {
        await RunAsync(async () =>
        {
            _analysis = await QuestionnaireApiClient.GetStructuredAnalysisAsync(CancellationToken.None);
            _message = "Analyse structurée actualisée.";
        });
    }

    private async Task LoadQuestionnairesCoreAsync()
    {
        IReadOnlyCollection<QuestionnaireDefinitionResponse> questionnaires =
            await QuestionnaireApiClient.ListAsync(CancellationToken.None);
        _questionnaires.Clear();
        _questionnaires.AddRange(questionnaires);
    }

    private async Task SelectQuestionnaireAsync(QuestionnaireDefinitionResponse questionnaire)
    {
        await RunAsync(async () =>
        {
            _selectedQuestionnaire = questionnaire;
            _progress = await QuestionnaireApiClient.GetProgressAsync(questionnaire.QuestionnaireId, CancellationToken.None);
            _answers.Clear();

            foreach (QuestionnaireAnswerResponse answer in _progress.Answers)
            {
                _answers[answer.QuestionId] = answer.Value;
            }

            _message = $"Questionnaire '{questionnaire.Title}' chargé.";
        });
    }

    private Task SaveDraftAsync()
    {
        return SaveAsync(submit: false);
    }

    private Task SubmitAsync()
    {
        return SaveAsync(submit: true);
    }

    private async Task SaveAsync(bool submit)
    {
        if (_selectedQuestionnaire is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            QuestionnaireAnswerRequest[] answers = _selectedQuestionnaire.Questions
                .Select(question => new QuestionnaireAnswerRequest(question.QuestionId, GetAnswer(question.QuestionId)))
                .ToArray();
            _progress = await QuestionnaireApiClient.SaveAsync(
                _selectedQuestionnaire.QuestionnaireId,
                answers,
                submit,
                CancellationToken.None);

            if (submit)
            {
                _analysis = await QuestionnaireApiClient.GetStructuredAnalysisAsync(CancellationToken.None);
            }

            _message = submit ? "Questionnaire soumis et analyse actualisée." : "Brouillon enregistré.";
        });
    }

    private string GetAnswer(string questionId)
    {
        return _answers.TryGetValue(questionId, out string? value) ? value : string.Empty;
    }

    private void SetAnswer(string questionId, string? value)
    {
        _answers[questionId] = value ?? string.Empty;
    }

    private async Task LogoutAsync()
    {
        await RunAsync(async () =>
        {
            await ApiClient.LogoutAsync();
            _context = null;
            _questionnaires.Clear();
            _selectedQuestionnaire = null;
            _progress = null;
            _analysis = null;
            _answers.Clear();
            _message = "Déconnexion locale effectuée.";
        });
    }

    private async Task RunAsync(Func<Task> action)
    {
        _isBusy = true;
        _message = null;

        try
        {
            await action();
        }
        catch (Exception exception)
        {
            _message = exception.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }
}
