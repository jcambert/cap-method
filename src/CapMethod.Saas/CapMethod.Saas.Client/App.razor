@namespace CapMethod.Saas.Client
@using CapMethod.Saas.Client.Auth
@using CapMethod.Saas.Shared.Beneficiaries
@using CapMethod.Saas.Shared.CapSessions
@inject CapMethodApiClient ApiClient

<main class="cap-shell">
    <section class="cap-hero">
        <p class="cap-kicker">CAP Method SaaS</p>
        <h1>v3.0-saas</h1>
        <p>Blazor WebAssembly hosted · Azure requis : non · IA requise : non</p>
    </section>

    <section class="cap-card">
        <h2>Authentification</h2>
        <p>Mode Lot 12 : connexion dev JWT, création bénéficiaire, création session CAP et liste des sessions du tenant connecté.</p>

        <div class="cap-actions">
            <button @onclick="LoginDevelopmentAsync" disabled="@_isBusy">Connexion dev</button>
            <button @onclick="LoadCurrentUserAsync" disabled="@_isBusy">Lire /api/me</button>
            <button @onclick="LoadCapSessionsAsync" disabled="@_isBusy">Rafraîchir les sessions</button>
            <button @onclick="LogoutAsync" disabled="@_isBusy">Déconnexion</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <p class="cap-message">@_message</p>
        }
    </section>

    @if (_token is not null)
    {
        <section class="cap-card">
            <h2>Token courant</h2>
            <dl>
                <dt>Type</dt>
                <dd>@_token.TokenType</dd>
                <dt>Expiration UTC</dt>
                <dd>@_token.ExpiresAtUtc</dd>
                <dt>Tenant</dt>
                <dd>@_token.TenantId</dd>
                <dt>Utilisateur</dt>
                <dd>@_token.UserId</dd>
            </dl>
        </section>
    }

    @if (_currentUser is not null)
    {
        <section class="cap-card">
            <h2>Contexte serveur</h2>
            <dl>
                <dt>Tenant</dt>
                <dd>@_currentUser.TenantId</dd>
                <dt>Utilisateur</dt>
                <dd>@_currentUser.UserId</dd>
                <dt>Authentifié</dt>
                <dd>@_currentUser.IsAuthenticated</dd>
                <dt>Fallback dev</dt>
                <dd>@_currentUser.IsDevelopmentFallback</dd>
            </dl>
        </section>
    }

    <section class="cap-card">
        <h2>Créer un bénéficiaire</h2>
        <p>Le tenant n'est pas saisi côté client. Il est injecté côté serveur à partir du token JWT.</p>

        <div class="cap-form-grid">
            <label>
                Prénom
                <input @bind="_beneficiaryFirstName" placeholder="Camille" />
            </label>
            <label>
                Nom
                <input @bind="_beneficiaryLastName" placeholder="Dupont" />
            </label>
            <label>
                Email
                <input @bind="_beneficiaryEmail" placeholder="camille.dupont@example.com" />
            </label>
        </div>

        <div class="cap-actions">
            <button @onclick="CreateBeneficiaryAsync" disabled="@_isBusy">Créer le bénéficiaire</button>
        </div>
    </section>

    @if (_createdBeneficiary is not null)
    {
        <section class="cap-card cap-success-card">
            <h2>Bénéficiaire créé</h2>
            <dl>
                <dt>Identifiant</dt>
                <dd>@_createdBeneficiary.BeneficiaryId</dd>
                <dt>Tenant</dt>
                <dd>@_createdBeneficiary.TenantId</dd>
                <dt>Prénom</dt>
                <dd>@_createdBeneficiary.FirstName</dd>
                <dt>Nom</dt>
                <dd>@_createdBeneficiary.LastName</dd>
                <dt>Email</dt>
                <dd>@(_createdBeneficiary.Email ?? "-")</dd>
                <dt>Créé UTC</dt>
                <dd>@_createdBeneficiary.CreatedAtUtc</dd>
            </dl>
        </section>

        <section class="cap-card">
            <h2>Créer une session CAP</h2>
            <p>La session est créée pour le bénéficiaire ci-dessus. Le consultant et le tenant sont résolus côté serveur depuis le token JWT.</p>

            <label class="cap-checkbox">
                <input type="checkbox" @bind="EnableAiForSession" />
                Activer l'IA pour cette session
            </label>

            <div class="cap-actions">
                <button @onclick="CreateCapSessionAsync" disabled="@_isBusy">Créer la session CAP</button>
            </div>
        </section>
    }

    @if (_createdSession is not null)
    {
        <section class="cap-card cap-success-card">
            <h2>Session CAP créée</h2>
            <dl>
                <dt>Session</dt>
                <dd>@_createdSession.CapSessionId</dd>
                <dt>Tenant</dt>
                <dd>@_createdSession.TenantId</dd>
                <dt>Bénéficiaire</dt>
                <dd>@_createdSession.BeneficiaryId</dd>
                <dt>Consultant</dt>
                <dd>@_createdSession.ConsultantId</dd>
                <dt>Statut</dt>
                <dd>@_createdSession.Status</dd>
                <dt>IA activée</dt>
                <dd>@_createdSession.IsAiEnabled</dd>
                <dt>Créée UTC</dt>
                <dd>@_createdSession.CreatedAtUtc</dd>
            </dl>
        </section>
    }

    <section class="cap-card">
        <h2>Sessions CAP du tenant</h2>
        <p>La liste est chargée via <code>GET /api/cap-sessions</code> avec le token Bearer courant.</p>

        <div class="cap-actions">
            <button @onclick="LoadCapSessionsAsync" disabled="@_isBusy">Rafraîchir</button>
        </div>

        @if (_capSessions.Count == 0)
        {
            <p>Aucune session chargée.</p>
        }
        else
        {
            <div class="cap-table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>Session</th>
                            <th>Bénéficiaire</th>
                            <th>Statut</th>
                            <th>IA</th>
                            <th>Créée UTC</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (CapSessionSummaryResponse session in _capSessions)
                        {
                            <tr>
                                <td>@session.CapSessionId</td>
                                <td>@session.BeneficiaryId</td>
                                <td>@session.Status</td>
                                <td>@session.IsAiEnabled</td>
                                <td>@session.CreatedAtUtc</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</main>

<style>
    .cap-shell {
        max-width: 1040px;
        margin: 0 auto;
        padding: 32px;
        font-family: system-ui, sans-serif;
    }

    .cap-hero,
    .cap-card {
        border: 1px solid #d6d9df;
        border-radius: 18px;
        padding: 24px;
        margin-bottom: 18px;
        background: #ffffff;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    }

    .cap-success-card {
        border-color: #16a34a;
    }

    .cap-kicker {
        margin: 0 0 8px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        font-size: 0.78rem;
        color: #475569;
    }

    .cap-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 18px;
    }

    .cap-form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 14px;
        margin-top: 18px;
    }

    label {
        display: grid;
        gap: 6px;
        font-weight: 700;
    }

    .cap-checkbox {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 18px;
    }

    input {
        border: 1px solid #cbd5e1;
        border-radius: 12px;
        padding: 10px 12px;
        font: inherit;
    }

    input[type="checkbox"] {
        width: 18px;
        height: 18px;
        padding: 0;
    }

    button {
        border: 0;
        border-radius: 999px;
        padding: 10px 16px;
        cursor: pointer;
        font-weight: 700;
    }

    button:disabled {
        cursor: not-allowed;
        opacity: 0.6;
    }

    .cap-message {
        margin-top: 16px;
        font-weight: 700;
    }

    .cap-table-wrap {
        overflow-x: auto;
        margin-top: 18px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.92rem;
    }

    th,
    td {
        border-bottom: 1px solid #e2e8f0;
        padding: 10px;
        text-align: left;
        vertical-align: top;
        word-break: break-all;
    }

    th {
        font-weight: 800;
    }

    dl {
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 8px 16px;
    }

    dt {
        font-weight: 700;
    }

    dd {
        margin: 0;
        word-break: break-all;
    }
</style>

@code {
    private bool _isBusy;
    private string? _message;
    private DevelopmentTokenResponse? _token;
    private CurrentUserResponse? _currentUser;
    private BeneficiaryResponse? _createdBeneficiary;
    private CapSessionResponse? _createdSession;
    private IReadOnlyCollection<CapSessionSummaryResponse> _capSessions = [];
    private string _beneficiaryFirstName = "Camille";
    private string _beneficiaryLastName = "Dupont";
    private string? _beneficiaryEmail = "camille.dupont@example.com";

    private bool EnableAiForSession { get; set; } = false;

    private async Task LoginDevelopmentAsync()
    {
        await RunAsync(async () =>
        {
            _token = await ApiClient.CreateDevelopmentTokenAsync(CancellationToken.None);
            _currentUser = await ApiClient.GetCurrentUserAsync(CancellationToken.None);
            _capSessions = await ApiClient.ListCapSessionsAsync(CancellationToken.None);
            _message = "Connexion développement réussie.";
        });
    }

    private async Task LoadCurrentUserAsync()
    {
        await RunAsync(async () =>
        {
            _currentUser = await ApiClient.GetCurrentUserAsync(CancellationToken.None);
            _message = "Contexte serveur chargé.";
        });
    }

    private async Task LoadCapSessionsAsync()
    {
        await RunAsync(async () =>
        {
            _capSessions = await ApiClient.ListCapSessionsAsync(CancellationToken.None);
            _message = $"Sessions chargées : {_capSessions.Count}.";
        });
    }

    private async Task CreateBeneficiaryAsync()
    {
        await RunAsync(async () =>
        {
            if (string.IsNullOrWhiteSpace(_beneficiaryFirstName) || string.IsNullOrWhiteSpace(_beneficiaryLastName))
            {
                throw new InvalidOperationException("Le prénom et le nom sont obligatoires.");
            }

            _createdBeneficiary = await ApiClient.CreateBeneficiaryAsync(
                _beneficiaryFirstName,
                _beneficiaryLastName,
                _beneficiaryEmail,
                CancellationToken.None);

            _createdSession = null;
            _message = "Bénéficiaire créé avec succès.";
        });
    }

    private async Task CreateCapSessionAsync()
    {
        await RunAsync(async () =>
        {
            if (_createdBeneficiary is null)
            {
                throw new InvalidOperationException("Un bénéficiaire doit être créé avant de créer une session CAP.");
            }

            _createdSession = await ApiClient.CreateCapSessionAsync(
                _createdBeneficiary.BeneficiaryId,
                EnableAiForSession,
                CancellationToken.None);

            _capSessions = await ApiClient.ListCapSessionsAsync(CancellationToken.None);
            _message = "Session CAP créée avec succès.";
        });
    }

    private async Task LogoutAsync()
    {
        await RunAsync(async () =>
        {
            await ApiClient.LogoutAsync();
            _token = null;
            _currentUser = null;
            _createdBeneficiary = null;
            _createdSession = null;
            _capSessions = [];
            _message = "Déconnexion locale effectuée.";
        });
    }

    private async Task RunAsync(Func<Task> action)
    {
        _isBusy = true;
        _message = null;

        try
        {
            await action();
        }
        catch (Exception exception)
        {
            _message = exception.Message;
        }
        finally
        {
            _isBusy = false;
        }
    }
}
